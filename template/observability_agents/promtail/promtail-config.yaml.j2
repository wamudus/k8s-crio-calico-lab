server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: {{ promtail_loki_url | default('http://localhost:3100/loki/api/v1/push') }}
    external_labels:
      hostname: {{ inventory_hostname }}


scrape_configs:
  - job_name: system
    static_configs:
      - targets:
          - localhost
        labels:
          job: varlogs
          __path__: /var/log/{messages,secure,cron,dnf.log}
